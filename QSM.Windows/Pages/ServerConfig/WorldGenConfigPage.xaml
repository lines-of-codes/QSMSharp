<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QSM.Windows.Pages.ServerConfig.WorldGenConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QSM.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="16" Margin="30,20">
        <TextBox x:Uid="/ServerConfig/LevelName" x:Name="LevelNameInput" 
                 Text="{x:Bind _worldSettings.LevelName, Mode=TwoWay}" />

        <TextBox x:Uid="/ServerConfig/LevelSeed" x:Name="LevelSeedInput" 
                 Text="{x:Bind _worldSettings.LevelSeed, Mode=TwoWay}" />
        
        <TextBox x:Uid="/ServerConfig/GeneratorSettings" 
                 Text="{x:Bind _worldSettings.GeneratorSettings, Mode=TwoWay}"
                 x:Name="GeneratorSettingsInput" />

        <NumberBox x:Uid="/ServerConfig/MaxWorldSize" Maximum="29999984" Minimum="1" x:Name="MaxWorldSizeInput"
                   Value="{x:Bind _worldSettings.MaxWorldSize, Mode=TwoWay}"/>

        <ComboBox x:Uid="/ServerConfig/LevelType" ItemsSource="{x:Bind _levelTypes, Mode=OneWay}"
                  SelectedItem="{x:Bind _worldSettings.LevelType, Mode=TwoWay}" x:Name="LevelTypeComboBox" />

        <CheckBox x:Uid="/ServerConfig/GenerateStructures" x:Name="GenerateStructuresCheckbox"
                  IsChecked="{x:Bind _worldSettings.GenerateStructures, Mode=TwoWay}" />
    </StackPanel>
</Page>
