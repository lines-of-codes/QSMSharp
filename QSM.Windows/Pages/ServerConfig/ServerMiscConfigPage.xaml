<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QSM.Windows.Pages.ServerConfig.ServerMiscConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QSM.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="16" Margin="30,20">
        <TextBox x:Uid="/ServerConfig/MOTD" Text="{x:Bind _settings.MOTD, Mode=TwoWay}" />
        <NumberBox x:Uid="/ServerConfig/PlayerIdleTimeout" 
                   Value="{x:Bind _settings.PlayerIdleTimeout, Mode=TwoWay}" />
        <NumberBox x:Uid="/ServerConfig/RateLimit" Value="{x:Bind _settings.RateLimit, Mode=TwoWay}" />
        <TextBox x:Uid="/ServerConfig/ResourcePack" Text="{x:Bind _settings.ResourcePack, Mode=TwoWay}" />
        <TextBox x:Uid="/ServerConfig/ResourcePackSha1" Text="{x:Bind _settings.ResourcePackSha1, Mode=TwoWay}" />
        <CheckBox x:Uid="/ServerConfig/RequireResourcePack" 
                  IsChecked="{x:Bind _settings.RequireResourcePack, Mode=TwoWay}" />
    </StackPanel>
</Page>
