<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QSM.Windows.Pages.ServerConfig.ServerConfigurationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QSM.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <NavigationView
        IsBackButtonVisible="Collapsed"
        IsBackEnabled="False"
        SelectionFollowsFocus="Enabled"
        IsPaneToggleButtonVisible="False"
        PaneDisplayMode="Left"
        IsSettingsVisible="False"
        SelectionChanged="ConfigurationNavigationView_SelectionChanged"
        x:Name="ConfigurationNavigationView">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Uid="/ServerConfig/WorldGenTab" x:Name="WorldGenTab" />
            <NavigationViewItem x:Uid="/ServerConfig/GameplayTab" x:Name="GameplayTab" />
            <NavigationViewItem x:Uid="/ServerConfig/PerformanceTab" x:Name="PerformanceTab" />
			<NavigationViewItem x:Uid="/ServerConfig/NetworkTab" x:Name="NetworkTab" />
			<NavigationViewItem x:Uid="/ServerConfig/PlayerInteractTab" x:Name="PlayerInteractTab" />
			<NavigationViewItem x:Uid="/ServerConfig/SecurityTab" x:Name="SecurityTab" />
			<NavigationViewItem x:Uid="/ServerConfig/DebugTab" x:Name="DebugTab" />
			<NavigationViewItem x:Uid="/ServerConfig/MiscTab" x:Name="MiscTab" />
            <NavigationViewItem Content="Java" x:Name="JavaTab" />
        </NavigationView.MenuItems>

        <Frame x:Name="ConfigurationFrame" />
    </NavigationView>
</Page>
